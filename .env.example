# ===========================================
# Romelly AI - Environment Variables
# ===========================================

# Server
PORT=4000
NODE_ENV=production
APP_URL=https://app.romelly.ai

# Database (PostgreSQL de Dokploy)
DATABASE_URL=postgresql://user:password@postgres:5432/romelly

# Redis (para colas de procesamiento)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=generar-con-openssl-rand-base64-32
JWT_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.romelly.ai/api/auth/google/callback

# URLs
FRONTEND_URL=https://app.romelly.ai
BACKEND_URL=https://api.romelly.ai

# ============================================
# AI - Gemini (Transcripción + Análisis)
# ============================================
# Gemini 1.5 Pro para transcripción de audio
# Gemini 1.5 Flash para análisis y chat
GEMINI_API_KEY=tu-api-key-de-gemini

# Anthropic (opcional - análisis premium)
ANTHROPIC_API_KEY=

# OpenAI (opcional - embeddings alternativos)
OPENAI_API_KEY=

# ============================================
# Billing - Stripe
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# ============================================
# Email - Resend
# ============================================
RESEND_API_KEY=
EMAIL_FROM=Romelly AI <noreply@romelly.ai>

# ============================================
# Storage - S3/MinIO
# ============================================
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=romelly
S3_REGION=us-east-1

# ============================================
# Integrations (usuarios configuran en la app)
# ============================================
# Estas son plantillas - los usuarios las configuran por organización

# Linear (para exportar action items)
# LINEAR_API_KEY=lin_api_xxx

# Notion (para exportar resúmenes)
# NOTION_TOKEN=secret_xxx
# NOTION_DATABASE_ID=xxx

# Slack (para notificaciones)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ============================================
# Feature Flags
# ============================================
ENABLE_ADVANCED_ANALYSIS=true
ENABLE_COACHING=true
ENABLE_SEMANTIC_SEARCH=true
ENABLE_AI_CHAT=true

# ============================================
# Rate Limits
# ============================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
