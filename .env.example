# ===========================================
# MeetAnalyzer SaaS - Environment Variables
# ===========================================

# Database (PostgreSQL externo)
DATABASE_URL=postgresql://user:password@localhost:5432/meetanalyzer

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000

# Transcription (AssemblyAI)
ASSEMBLYAI_API_KEY=your-api-key

# Billing (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend)
RESEND_API_KEY=your-api-key
EMAIL_FROM=MeetAnalyzer <noreply@meetanalyzer.com>

# Storage (S3/MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=meetanalyzer
