# ===========================================
# MeetAnalyzer SaaS - Environment Variables
# ===========================================

# ===========================================
# 🐋 Docker Configuration
# ===========================================
# Puertos para docker-compose
API_PORT=4000
WEB_PORT=3000
REDIS_PORT=6379

# ===========================================
# 🗄️ Database (PostgreSQL externo - Dokploy)
# ===========================================
DATABASE_URL=postgresql://user:password@dokploy-postgres:5432/meetanalyzer

# ===========================================
# 🔴 Redis (interno en docker-compose)
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# 🔐 Authentication & Security
# ===========================================
# JWT Secret - Generate with: openssl rand -base64 32
JWT_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/auth/google/callback

# ===========================================
# 🌐 URLs
# ===========================================
# Producción
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# Desarrollo (comentar las de arriba y usar estas)
# FRONTEND_URL=http://localhost:3000
# BACKEND_URL=http://localhost:4000

# ===========================================
# 🤖 AI Services
# ===========================================
# Transcription (AssemblyAI)
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# LLM Providers (opcional - usuarios pueden usar sus propias keys)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=your-gemini-api-key

# ===========================================
# 💳 Billing (Stripe)
# ===========================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ===========================================
# 📧 Email (Resend)
# ===========================================
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=MeetAnalyzer <noreply@yourdomain.com>

# ===========================================
# 📁 Storage (S3/MinIO externo - Dokploy)
# ===========================================
# Usar AWS S3 en producción
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=meetanalyzer
AWS_REGION=us-east-1
AWS_CDN_URL=https://cdn.yourdomain.com

# Para desarrollo local con MinIO
# AWS_ENDPOINT=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# ===========================================
# 🔧 Application Settings
# ===========================================
# Node Environment
NODE_ENV=production

# Logging
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# File upload limits (en MB)
MAX_FILE_SIZE_MB=100

# Session settings
SESSION_TIMEOUT_HOURS=24
