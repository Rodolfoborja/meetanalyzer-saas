# ===========================================
# Romelly AI - Environment Variables
# ===========================================

# Server
PORT=4000
NODE_ENV=production

# Database (PostgreSQL de Dokploy)
DATABASE_URL=postgresql://user:password@postgres:5432/romelly

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=generar-con-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.tudominio.com/api/auth/google/callback

# URLs
FRONTEND_URL=https://app.tudominio.com
BACKEND_URL=https://api.tudominio.com

# ============================================
# AI - Solo necesitas Gemini!
# ============================================
GEMINI_API_KEY=tu-api-key-de-gemini

# Stripe (opcional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email - Resend (opcional)
RESEND_API_KEY=
EMAIL_FROM=Romelly AI <noreply@tudominio.com>

# S3/MinIO (opcional para archivos)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=romelly
