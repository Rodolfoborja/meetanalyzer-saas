generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Multi-tenant Core
// ============================================

model Organization {
  id        String   @id @default(cuid())
  slug      String   @unique // subdomain: empresa.romelly.ai
  name      String
  logo      String?
  plan      Plan     @default(FREE)
  
  // Stripe
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  
  // Usage limits
  monthlyMinutesLimit  Int      @default(60)
  monthlyMinutesUsed   Int      @default(0)
  maxUsers             Int      @default(1)
  
  // Settings
  defaultLlmProvider   LlmProvider @default(GEMINI)
  emailNotifications   Boolean     @default(true)
  slackWebhook         String?
  notionIntegration    Json?
  
  // Relations
  users        User[]
  meetings     Meeting[]
  invitations  Invitation[]
  webhooks     Webhook[]
  templates    MeetingTemplate[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  name      String?
  avatar    String?
  
  // OAuth
  googleId  String? @unique
  
  // Organization
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role         @default(MEMBER)
  
  // Personal API Keys (optional override)
  openaiApiKey    String?
  anthropicApiKey String?
  geminiApiKey    String?
  
  // Preferences
  preferredLanguage String @default("es")
  coachingEnabled   Boolean @default(true)
  
  // Relations
  meetings         Meeting[]
  comments         Comment[]
  actionItemsOwned ActionItem[] @relation("ActionItemOwner")
  aiChats          AiChatSession[]
  coachingReports  CoachingReport[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      Role     @default(MEMBER)
  token     String   @unique @default(cuid())
  expiresAt DateTime
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  invitedBy   String // User ID who invited
  
  createdAt DateTime @default(now())

  @@unique([email, organizationId])
  @@index([organizationId])
}

// ============================================
// Meetings & Analysis
// ============================================

model Meeting {
  id     String @id @default(cuid())
  
  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Meeting Info
  title       String
  description String?
  platform    MeetingPlatform @default(UPLOAD)
  meetingUrl  String?
  scheduledAt DateTime?
  duration    Int? // minutes
  
  // Template
  templateId  String?
  template    MeetingTemplate? @relation(fields: [templateId], references: [id])

  // Status
  status MeetingStatus @default(PENDING)

  // Audio
  audioUrl      String?
  audioFormat   String?
  audioDuration Float? // seconds
  minutesUsed   Int    @default(0) // Billed minutes

  // Sharing
  isPublic    Boolean @default(false)
  shareToken  String? @unique
  
  // Tags for search
  tags        String[]
  
  // Relations
  transcript   Transcript?
  analysis     Analysis?
  participants Participant[]
  comments     Comment[]
  actionItems  ActionItem[]
  aiChats      AiChatSession[]
  embeddings   MeetingEmbedding[]
  exports      Export[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([shareToken])
}

model Transcript {
  id        String  @id @default(cuid())
  meetingId String  @unique
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  content   Json   // Array of {timestamp, speaker, text}
  rawText   String @db.Text
  wordCount Int

  language        String  @default("es")
  confidence      Float?
  transcriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Analysis {
  id        String  @id @default(cuid())
  meetingId String  @unique
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  llmProvider LlmProvider
  model       String

  summary     String @db.Text
  keyPoints   Json
  actionItems Json   // Legacy - now use ActionItem model
  decisions   Json
  followUps   Json
  
  // NEW: Advanced Analysis
  topics          Json?  // Topic clustering with confidence
  sentiment       Json?  // Overall and per-speaker sentiment
  meetingType     MeetingType?
  effectivenessScore Int? // 1-100
  suggestions     Json?  // AI suggestions for improvement

  oratoryMetrics Json?
  rawResponse    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Participant {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  speakerLabel   String
  name           String?
  email          String?
  speakingTime   Int     @default(0)
  wordCount      Int     @default(0)
  turnCount      Int     @default(0)
  wordsPerMinute Float?
  fillerWords    Json?
  
  // NEW: Sentiment & Engagement
  sentimentScore    Float?  // -1 to 1
  engagementLevel   Float?  // 0 to 1
  dominanceScore    Float?  // 0 to 1 (how much they dominated)
  interruptionCount Int     @default(0)
  questionsAsked    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([meetingId, speakerLabel])
  @@index([meetingId])
}

// ============================================
// 🎯 Action Items with Tracking
// ============================================

model ActionItem {
  id        String @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  
  // Assignment
  assigneeId  String?
  assignee    User?   @relation("ActionItemOwner", fields: [assigneeId], references: [id])
  assigneeName String? // For external assignees
  
  // Tracking
  status      ActionItemStatus @default(PENDING)
  priority    Priority         @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  
  // Source
  sourceTimestamp Int?    // Second in meeting where it was mentioned
  sourceText      String? // Exact quote
  
  // Integration sync
  linearIssueId   String?
  notionPageId    String?
  jiraTicketId    String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId])
  @@index([assigneeId])
  @@index([status])
}

// ============================================
// 💬 Real-time Collaboration
// ============================================

model Comment {
  id        String @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  content   String @db.Text
  timestamp Int?   // Optional: linked to specific moment in meeting
  
  // Thread support
  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")
  
  // Reactions
  reactions Json? // {emoji: [userId, ...]}
  
  resolved Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId])
  @@index([userId])
}

// ============================================
// 🤖 AI Meeting Assistant (Chat)
// ============================================

model AiChatSession {
  id        String @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  messages AiChatMessage[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId])
  @@index([userId])
}

model AiChatMessage {
  id        String @id @default(cuid())
  sessionId String
  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  role    ChatRole
  content String   @db.Text
  
  // For citations
  citations Json? // [{timestamp, speaker, text}]
  
  createdAt DateTime @default(now())

  @@index([sessionId])
}

// ============================================
// 🔍 Semantic Search (Vector Embeddings)
// ============================================

model MeetingEmbedding {
  id        String @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  // Chunk info
  chunkIndex Int
  chunkText  String @db.Text
  timestamp  Int?   // Start timestamp of chunk
  speaker    String?
  
  // Vector (stored as JSON for Postgres, use pgvector in prod)
  embedding  Json // Float array [768] or [1536]
  
  createdAt DateTime @default(now())

  @@unique([meetingId, chunkIndex])
  @@index([meetingId])
}

// ============================================
// 📊 AI Coaching & Personal Insights
// ============================================

model CoachingReport {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Time period
  periodStart DateTime
  periodEnd   DateTime
  meetingCount Int
  
  // Aggregated metrics
  avgSpeakingPace    Float?
  avgFillerWordRate  Float?
  avgParticipation   Float?
  avgSentiment       Float?
  
  // AI-generated insights
  strengths     Json  // ["Clear communication", "Good questions"]
  improvements  Json  // ["Reduce filler words", "Allow others to speak"]
  tips          Json  // Actionable tips
  comparison    Json? // Comparison to previous period
  
  // Goals
  goals         Json? // User-set goals for next period
  goalProgress  Json? // Progress on previous goals
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([periodStart, periodEnd])
}

// ============================================
// 📝 Meeting Templates
// ============================================

model MeetingTemplate {
  id             String @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  type        MeetingType
  icon        String?
  
  // Template config
  defaultDuration   Int?     // minutes
  suggestedAgenda   Json?    // ["Item 1", "Item 2"]
  extractionRules   Json?    // Custom extraction rules
  promptOverrides   Json?    // Custom prompts for this type
  
  // Auto-actions
  autoCreateTasks   Boolean @default(true)
  autoShare         Json?   // Auto-share settings
  
  isDefault Boolean @default(false)
  
  meetings Meeting[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// ============================================
// 🔗 Integrations & Webhooks
// ============================================

model Webhook {
  id             String @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name    String
  url     String
  secret  String? // For HMAC signing
  
  events  WebhookEvent[]
  enabled Boolean @default(true)
  
  // Stats
  lastTriggered DateTime?
  failureCount  Int @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// ============================================
// 📤 Exports
// ============================================

model Export {
  id        String @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  format     ExportFormat
  status     ExportStatus @default(PENDING)
  fileUrl    String?
  error      String?
  
  // Options used
  options    Json?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId])
}

// ============================================
// Billing
// ============================================

model SubscriptionEvent {
  id        String   @id @default(cuid())
  
  organizationId String
  
  eventType  String // invoice.paid, subscription.updated, etc.
  stripeEventId String @unique
  data       Json
  
  createdAt DateTime @default(now())

  @@index([organizationId])
}

// ============================================
// Enums
// ============================================

enum Plan {
  FREE        // 60 min/mes, 1 usuario
  STARTER     // 300 min/mes, 5 usuarios - $19/mes
  PRO         // 1000 min/mes, 20 usuarios - $49/mes
  ENTERPRISE  // Ilimitado - Custom
}

enum Role {
  OWNER   // Full access + billing
  ADMIN   // Full access except billing
  MEMBER  // CRUD own meetings
  VIEWER  // Read only
}

enum MeetingPlatform {
  GOOGLE_MEET
  MICROSOFT_TEAMS
  ZOOM
  UPLOAD
  RECORDING_BOT // Future: auto-join bots
}

enum MeetingStatus {
  PENDING
  UPLOADING
  TRANSCRIBING
  ANALYZING
  COMPLETED
  ERROR
}

enum LlmProvider {
  OPENAI
  ANTHROPIC
  GEMINI
}

enum MeetingType {
  ONE_ON_ONE
  STANDUP
  SPRINT_PLANNING
  RETROSPECTIVE
  BRAINSTORM
  CLIENT_CALL
  INTERVIEW
  ALL_HANDS
  WORKSHOP
  OTHER
}

enum ActionItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ChatRole {
  USER
  ASSISTANT
}

enum WebhookEvent {
  MEETING_CREATED
  MEETING_COMPLETED
  ACTION_ITEM_CREATED
  ACTION_ITEM_COMPLETED
  ANALYSIS_READY
}

enum ExportFormat {
  PDF
  DOCX
  MARKDOWN
  NOTION
  LINEAR
  JIRA
}

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
